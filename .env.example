# Local secrets. Copy this file to .env and fill in real values.
# Never commit .env.

# Set production to fail closed unless Clerk is configured.
APP_ENV=development
CORS_ALLOWED_ORIGINS=http://localhost:3000

# OpenAI powers structured company-profile, query, and claim extraction.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TITLE_MODEL=gpt-4o-mini
OPENAI_CONTRADICTION_MAX_CALLS=8
OPENAI_FOUNDER_PASSPORT_MAX_CALLS=10
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe

# Web/source enrichment.
TAVILY_API_KEY=
PERPLEXITY_API_KEY=
EXA_API_KEY=
PRODUCT_HUNT_TOKEN=
OPENCORPORATES_API_TOKEN=

# ElevenLabs powers optional voice narration.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128

# Clerk authentication. Only the publishable key is exposed to the Next.js UI;
# backend credentials never go into browser code.
CLERK_SECRET_KEY=
CLERK_JWT_KEY=
CLERK_AUTHORIZED_PARTIES=http://localhost:3000
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=

# Local persistence.
VCBRAIN_DB_PATH=data/processed/vcbrain.sqlite3
